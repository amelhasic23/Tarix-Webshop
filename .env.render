# Render.com Configuration
# Add these to your Render environment variables

NODE_ENV=production
PORT=10000

# Session secret - generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your-64-char-random-string-here

# Force rebuild native modules
NPM_CONFIG_BUILD_FROM_SOURCE=true

# Python version for native modules
PYTHON_VERSION=3.9

# Node options to prevent memory issues
NODE_OPTIONS=--max-old-space-size=1024