# Dependencies
node_modules/
package-lock.json

# Environment variables
.env

# Database (not needed for static deployment)
database/tarix.db

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Build artifacts
# NOTE: Do NOT ignore *.min.js / *.min.css here. The site loads required assets
# from those paths (index.min.css, index.min.js, swiper-init.min.js and the
# third-party vendor/*.min.* libraries). Ignoring them kept them out of the
# deploy, so the server returned a JSON 404 and browsers refused them (wrong MIME).
index.min.html

# Temporary files
*.tmp
*.log
*.bak
temp_*
New Text Document*

# System files
Thumbs.db
desktop.ini

# Cache directories
.cache/
.qodo/
